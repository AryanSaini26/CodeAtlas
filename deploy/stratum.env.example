# Copy to /etc/stratum/stratum.env on the server. NEVER commit real values.
#   chown root:stratum /etc/stratum/stratum.env && chmod 640 /etc/stratum/stratum.env

# Public base URL (your DuckDNS domain). Used in GitHub App setup/webhook callbacks.
STRATUM_PUBLIC_URL=https://stratum.duckdns.org

# GitHub App credentials (from github.com/settings/apps).
STRATUM_GITHUB_APP_ID=
STRATUM_GITHUB_CLIENT_ID=
STRATUM_GITHUB_CLIENT_SECRET=
STRATUM_GITHUB_WEBHOOK_SECRET=

# Path to the App private key PEM. systemd EnvironmentFile can't hold multi-line
# values, so the key lives in a file (not inline). Place it here, chmod 640:
STRATUM_GITHUB_PRIVATE_KEY_PATH=/etc/stratum/github-app.pem

# DuckDNS dynamic DNS (free). DUCKDNS_DOMAIN is the subdomain label only,
# e.g. "stratum" for stratum.duckdns.org.
DUCKDNS_DOMAIN=stratum
DUCKDNS_TOKEN=

# Optional: enable the admin-only GET /api/hosted/v1/metrics endpoint. Leave
# unset to keep it disabled (404). Also available offline via
#   codeatlas hosted metrics --hosted-db /var/lib/stratum/hosted.db
# STRATUM_ADMIN_TOKEN=

# Optional: public read-only demo for the landing page's "Explore live demo".
# Run `codeatlas hosted seed-demo` once, then paste the printed values here.
# STRATUM_DEMO_REPO_ID=
# STRATUM_DEMO_TOKEN=

# Optional rate-limit overrides (defaults: 60/min webhook, ~2/s context).
# STRATUM_WEBHOOK_RATE_CAPACITY=60
# STRATUM_WEBHOOK_RATE_REFILL=1.0
# STRATUM_MCP_RATE_CAPACITY=120
# STRATUM_MCP_RATE_REFILL=2.0
